{
  "description": "Parser-differential spoof shape: a trusted authserv-id reports DMARC pass, but the From domain it evaluated (header.from=evil.test) differs from the From the recipient parses (example.com) — a DMARC pass badge applied to a domain the user never sees. SPF smtp.mailfrom, DKIM header.d, and Message-ID all align with the visible From, isolating the header.from-vs-From comparison. dmarcHeaderFromMatchesFromDomain is false and a single low-severity dmarc.headerFromMismatch signal is emitted carrying the visible From domain, all trusted+passing header.from domains, and the mismatching subset. Low severity reflects that exact comparison (no PSL/org-domain logic) can also flag benign subdomain/org differences.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<abc123@example.com>",
      "authentication-results": [
        "mx.example.net; dmarc=pass header.from=evil.test; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": ["example.com"],
      "dkimDomainMatchesFromDomain": true,
      "dmarcHeaderFromDomains": ["evil.test"],
      "dmarcHeaderFromMatchesFromDomain": false,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [
          { "result": "pass", "headerFrom": "evil.test", "trusted": true }
        ],
        "spfResults": [
          { "result": "pass", "smtpMailfrom": "example.com", "trusted": true }
        ],
        "dkimResults": [
          { "result": "pass", "headerD": "example.com", "headerI": null, "trusted": true }
        ],
        "spfAlignedWithFrom": true,
        "dkimAlignedWithFrom": true,
        "anyAlignedSpfPass": true,
        "anyAlignedDkimPass": true,
        "dmarcPass": true,
        "anyAuthAligned": true
      },
      "senderIdentity": {
        "displayName": {
          "present": true,
          "text": "Example Sender",
          "length": 14,
          "hasNonAscii": false,
          "containsEmail": false,
          "embeddedDomains": [],
          "embeddedDomainMatchesFromDomain": null,
          "normalized": { "compactedWhitespace": "ExampleSender" },
          "metrics": { "whitespaceCompactedChanged": true },
          "signals": { "spacedDisplayNameCamouflageCandidate": false }
        },
        "localPart": "notice",
        "localPartLexical": { "length": 6, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainLexical": { "length": 11, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdRegistrableDomainMatchesFromDomain": null,
        "fromDomainIsPublicMailboxProvider": false,
        "publicMailboxProviderId": null
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; dmarc=pass header.from=evil.test; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            { "method": "dmarc", "result": "pass", "properties": { "header.from": "evil.test" } },
            { "method": "spf", "result": "pass", "properties": { "smtp.mailfrom": "example.com" } },
            { "method": "dkim", "result": "pass", "properties": { "header.d": "example.com" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "dmarc.headerFromMismatch",
        "category": "consistency",
        "severity": "low",
        "message": "DMARC header.from domain differs from the visible From domain.",
        "data": {
          "fromDomain": "example.com",
          "dmarcHeaderFromDomains": ["evil.test"],
          "mismatchedDomains": ["evil.test"]
        }
      }
    ]
