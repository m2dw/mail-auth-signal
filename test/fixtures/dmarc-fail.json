{
  "description": "DMARC fails on a header from an undeclared (untrusted) authserv-id, and the Message-ID domain differs from the From domain. Because the authserv-id is untrusted the failure is non-authoritative (it could be forged) and is reported at low severity with trusted:false, while untrustedAuthservIdRule separately flags the source. Demonstrates the full serializable AnalyzeResult shape that follow-up rule-migration issues target.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<abc123@mailer.example.net>",
      "authentication-results": [
        "mx.example.net; dmarc=fail header.from=example.com; spf=pass smtp.mailfrom=example.com"
      ]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "mailer.example.net",
      "messageIdDomainMatchesFromDomain": false,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": [],
      "dkimDomainMatchesFromDomain": null,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 0,
        "untrustedHeaderCount": 1,
        "dmarcResults": [
          { "result": "fail", "headerFrom": "example.com", "trusted": false }
        ],
        "spfResults": [
          { "result": "pass", "smtpMailfrom": "example.com", "trusted": false }
        ],
        "dkimResults": [],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; dmarc=fail header.from=example.com; spf=pass smtp.mailfrom=example.com",
          "authservId": "mx.example.net",
          "trusted": false,
          "methods": [
            {
              "method": "dmarc",
              "result": "fail",
              "properties": { "header.from": "example.com" }
            },
            {
              "method": "spf",
              "result": "pass",
              "properties": { "smtp.mailfrom": "example.com" }
            }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.results.untrusted",
        "category": "trust",
        "severity": "low",
        "message": "Authentication-Results header was produced by an untrusted authserv-id.",
        "data": { "authservId": "mx.example.net" }
      },
      {
        "key": "auth.method.failure",
        "category": "auth-failure",
        "severity": "low",
        "message": "DMARC returned fail.",
        "data": {
          "method": "dmarc",
          "result": "fail",
          "authservId": "mx.example.net",
          "trusted": false,
          "properties": { "header.from": "example.com" }
        }
      },
      {
        "key": "messageId.domainMismatch",
        "category": "consistency",
        "severity": "low",
        "message": "Message-ID domain differs from the From domain.",
        "data": {
          "fromDomain": "example.com",
          "messageIdDomain": "mailer.example.net",
          "mismatchedDomains": ["mailer.example.net"]
        }
      }
    ]
  }
}
