{
  "description": "Authentication + alignment metrics on a trusted, fully From-aligned message that also carries a DKIM header.i (AUID) and a second, third-party DKIM signature. Layer 1 records every DMARC/SPF/DKIM result with its identifiers (including the normalized header.i domain news.example.com) and trust tag; Layer 2 shows the aligned author-domain signature makes anyAlignedDkimPass true while the extra mailer.test signature keeps dkimAlignedWithFrom false (any-vs-all alignment). The mailer.test signing domain also drives the one dkim.domainMismatch consistency hint; everything else aligns.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<abc123@example.com>",
      "authentication-results": [
        "mx.example.net; dmarc=pass header.from=example.com; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com header.i=@news.example.com; dkim=pass header.d=mailer.test"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": ["example.com", "mailer.test"],
      "dkimDomainMatchesFromDomain": false,
      "dmarcHeaderFromDomains": ["example.com"],
      "dmarcHeaderFromMatchesFromDomain": true,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [
          { "result": "pass", "headerFrom": "example.com", "trusted": true }
        ],
        "spfResults": [
          { "result": "pass", "smtpMailfrom": "example.com", "trusted": true }
        ],
        "dkimResults": [
          { "result": "pass", "headerD": "example.com", "headerI": "news.example.com", "trusted": true },
          { "result": "pass", "headerD": "mailer.test", "headerI": null, "trusted": true }
        ],
        "spfAlignedWithFrom": true,
        "dkimAlignedWithFrom": false,
        "anyAlignedSpfPass": true,
        "anyAlignedDkimPass": true,
        "dmarcPass": true,
        "anyAuthAligned": true
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; dmarc=pass header.from=example.com; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com header.i=@news.example.com; dkim=pass header.d=mailer.test",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            { "method": "dmarc", "result": "pass", "properties": { "header.from": "example.com" } },
            { "method": "spf", "result": "pass", "properties": { "smtp.mailfrom": "example.com" } },
            { "method": "dkim", "result": "pass", "properties": { "header.d": "example.com", "header.i": "@news.example.com" } },
            { "method": "dkim", "result": "pass", "properties": { "header.d": "mailer.test" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "dkim.domainMismatch",
        "category": "consistency",
        "severity": "low",
        "message": "DKIM header.d signing domain differs from the From domain.",
        "data": {
          "fromDomain": "example.com",
          "dkimDomains": ["example.com", "mailer.test"],
          "mismatchedDomains": ["mailer.test"]
        }
      }
    ]
  }
}
