{
  "description": "SPF softfail from a trusted authserv-id. A softfail (the domain's `~all`) is deliberately non-committal and is a common artifact of legitimate forwarding, so even from a trusted source it is reported low — the false-positive mitigation for forwarded mail. The forwarding envelope-from (smtp.mailfrom=fwd.example.org) also differs from the From domain, so a low-severity smtpMailfrom.domainMismatch consistency hint accompanies it — exactly the documented forwarding false-positive that keeps the envelope-sender signal low.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<abc123@example.com>",
      "authentication-results": [
        "mx.example.net; spf=softfail smtp.mailfrom=fwd.example.org"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["fwd.example.org"],
      "smtpMailfromDomainMatchesFromDomain": false,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": [],
      "dkimDomainMatchesFromDomain": null,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [],
        "spfResults": [
          { "result": "softfail", "smtpMailfrom": "fwd.example.org", "trusted": true }
        ],
        "dkimResults": [],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "senderIdentity": {
        "displayName": {
          "present": true,
          "text": "Example Sender",
          "length": 14,
          "hasNonAscii": false,
          "containsEmail": false,
          "embeddedDomains": [],
          "embeddedDomainMatchesFromDomain": null
        },
        "localPart": "notice",
        "localPartLexical": { "length": 6, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainLexical": { "length": 11, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdRegistrableDomainMatchesFromDomain": null,
        "fromDomainIsPublicMailboxProvider": false,
        "publicMailboxProviderId": null
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; spf=softfail smtp.mailfrom=fwd.example.org",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            {
              "method": "spf",
              "result": "softfail",
              "properties": { "smtp.mailfrom": "fwd.example.org" }
            }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.method.failure",
        "category": "auth-failure",
        "severity": "low",
        "message": "SPF returned softfail.",
        "data": {
          "method": "spf",
          "result": "softfail",
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "smtp.mailfrom": "fwd.example.org" }
        }
      },
      {
        "key": "smtpMailfrom.domainMismatch",
        "category": "consistency",
        "severity": "low",
        "message": "SPF smtp.mailfrom domain differs from the From domain.",
        "data": {
          "fromDomain": "example.com",
          "smtpMailfromDomains": ["fwd.example.org"],
          "mismatchedDomains": ["fwd.example.org"]
        }
      }
    ]
  }
}
