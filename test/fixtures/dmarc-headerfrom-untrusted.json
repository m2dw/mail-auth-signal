{
  "description": "Trust gating: an undeclared (untrusted) authserv-id reports DMARC pass with header.from=evil.test while the visible From is example.com. Because header.from is not cryptographic, a forge-able untrusted header's value is just the attacker's own assertion, so it is excluded from dmarcHeaderFromDomains entirely — the list is empty and dmarcHeaderFromMatchesFromDomain is null, emitting no dmarc.headerFromMismatch signal. Only untrustedAuthservIdRule flags the forge-able source. Confirms an untrusted DMARC context cannot manufacture a noisy consistency signal.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<abc123@example.com>",
      "authentication-results": [
        "relay.evil.test; dmarc=pass header.from=evil.test; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": ["example.com"],
      "dkimDomainMatchesFromDomain": true,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 0,
        "untrustedHeaderCount": 1,
        "dmarcResults": [
          { "result": "pass", "headerFrom": "evil.test", "trusted": false }
        ],
        "spfResults": [
          { "result": "pass", "smtpMailfrom": "example.com", "trusted": false }
        ],
        "dkimResults": [
          { "result": "pass", "headerD": "example.com", "headerI": null, "trusted": false }
        ],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "senderIdentity": {
        "displayName": {
          "present": true,
          "text": "Example Sender",
          "length": 14,
          "hasNonAscii": false,
          "containsEmail": false,
          "embeddedDomains": [],
          "embeddedDomainMatchesFromDomain": null,
          "normalized": { "compactedWhitespace": "ExampleSender" },
          "metrics": { "whitespaceCompactedChanged": true },
          "signals": { "spacedDisplayNameCamouflageCandidate": false }
        },
        "localPart": "notice",
        "localPartLexical": { "length": 6, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainLexical": { "length": 11, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdRegistrableDomainMatchesFromDomain": null
      },
      "authenticationResults": [
        {
          "raw": "relay.evil.test; dmarc=pass header.from=evil.test; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com",
          "authservId": "relay.evil.test",
          "trusted": false,
          "methods": [
            { "method": "dmarc", "result": "pass", "properties": { "header.from": "evil.test" } },
            { "method": "spf", "result": "pass", "properties": { "smtp.mailfrom": "example.com" } },
            { "method": "dkim", "result": "pass", "properties": { "header.d": "example.com" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.results.untrusted",
        "category": "trust",
        "severity": "low",
        "message": "Authentication-Results header was produced by an untrusted authserv-id.",
        "data": { "authservId": "relay.evil.test" }
      }
    ]
  }
}
