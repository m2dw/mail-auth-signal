{
  "description": "Direct-domain spoof: a trusted authserv-id reports DMARC, SPF, and DKIM all failing for the From domain. Because the authserv-id is trusted the results are authoritative, so DMARC fail (unaligned with the From domain) is reported high while the individual SPF and DKIM hard fails are medium. No untrusted-source or Message-ID-mismatch signals fire here, isolating the authoritative failure family.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<abc123@example.com>",
      "authentication-results": [
        "mx.example.net; dmarc=fail header.from=example.com; spf=fail smtp.mailfrom=example.com; dkim=fail header.d=example.com"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": [],
      "dkimDomainMatchesFromDomain": null,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [
          { "result": "fail", "headerFrom": "example.com", "trusted": true }
        ],
        "spfResults": [
          { "result": "fail", "smtpMailfrom": "example.com", "trusted": true }
        ],
        "dkimResults": [
          { "result": "fail", "headerD": "example.com", "headerI": null, "trusted": true }
        ],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "senderIdentity": {
        "displayName": {
          "present": true,
          "text": "Example Sender",
          "length": 14,
          "hasNonAscii": false,
          "containsEmail": false,
          "embeddedDomains": [],
          "embeddedDomainMatchesFromDomain": null,
          "normalized": { "compactedWhitespace": "ExampleSender" },
          "metrics": { "whitespaceCompactedChanged": true },
          "signals": { "spacedDisplayNameCamouflageCandidate": false }
        },
        "localPart": "notice",
        "localPartLexical": { "length": 6, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainLexical": { "length": 11, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdRegistrableDomainMatchesFromDomain": null,
        "fromDomainIsPublicMailboxProvider": false,
        "publicMailboxProviderId": null
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; dmarc=fail header.from=example.com; spf=fail smtp.mailfrom=example.com; dkim=fail header.d=example.com",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            {
              "method": "dmarc",
              "result": "fail",
              "properties": { "header.from": "example.com" }
            },
            {
              "method": "spf",
              "result": "fail",
              "properties": { "smtp.mailfrom": "example.com" }
            },
            {
              "method": "dkim",
              "result": "fail",
              "properties": { "header.d": "example.com" }
            }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.method.failure",
        "category": "auth-failure",
        "severity": "high",
        "message": "DMARC returned fail.",
        "data": {
          "method": "dmarc",
          "result": "fail",
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "header.from": "example.com" }
        }
      },
      {
        "key": "auth.method.failure",
        "category": "auth-failure",
