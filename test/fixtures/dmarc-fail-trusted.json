{
  "description": "Direct-domain spoof: a trusted authserv-id reports DMARC, SPF, and DKIM all failing for the From domain. Because the authserv-id is trusted the results are authoritative, so DMARC fail (unaligned with the From domain) is reported high while the individual SPF and DKIM hard fails are medium. No untrusted-source or Message-ID-mismatch signals fire here, isolating the authoritative failure family.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<abc123@example.com>",
      "authentication-results": [
        "mx.example.net; dmarc=fail header.from=example.com; spf=fail smtp.mailfrom=example.com; dkim=fail header.d=example.com"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": [],
      "dkimDomainMatchesFromDomain": null,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authenticationResults": [
        {
          "raw": "mx.example.net; dmarc=fail header.from=example.com; spf=fail smtp.mailfrom=example.com; dkim=fail header.d=example.com",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            {
              "method": "dmarc",
              "result": "fail",
              "properties": { "header.from": "example.com" }
            },
            {
              "method": "spf",
              "result": "fail",
              "properties": { "smtp.mailfrom": "example.com" }
            },
            {
              "method": "dkim",
              "result": "fail",
              "properties": { "header.d": "example.com" }
            }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.dmarc.fail",
        "severity": "high",
        "message": "DMARC returned fail.",
        "data": {
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "header.from": "example.com" }
        }
      },
      {
        "key": "auth.spf.fail",
        "severity": "medium",
        "message": "SPF returned fail.",
        "data": {
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "smtp.mailfrom": "example.com" }
        }
      },
      {
        "key": "auth.dkim.fail",
        "severity": "medium",
        "message": "DKIM returned fail.",
        "data": {
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "header.d": "example.com" }
        }
      }
    ]
  }
}
