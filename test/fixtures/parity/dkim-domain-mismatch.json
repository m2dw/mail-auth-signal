{
  "family": "dkim.domainMismatch",
  "description": "From is example.com but the only passing DKIM signature signs for attacker-controlled evil.test. SPF smtp.mailfrom and DMARC header.from stay From-aligned (so DMARC can pass on SPF alignment and the envelope-sender rules stay silent), isolating the DKIM header.d/From comparison. Low severity reflects that platforms also legitimately sign brand mail under their own domain.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<id@example.com>",
      "authentication-results": [
        "mx.example.net; dmarc=pass header.from=example.com; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=evil.test"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": ["evil.test"],
      "dkimDomainMatchesFromDomain": false,
      "dmarcHeaderFromDomains": ["example.com"],
      "dmarcHeaderFromMatchesFromDomain": true,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [
          { "result": "pass", "headerFrom": "example.com", "trusted": true }
        ],
        "spfResults": [
          { "result": "pass", "smtpMailfrom": "example.com", "trusted": true }
        ],
        "dkimResults": [
          { "result": "pass", "headerD": "evil.test", "headerI": null, "trusted": true }
        ],
        "spfAlignedWithFrom": true,
        "dkimAlignedWithFrom": false,
        "anyAlignedSpfPass": true,
        "anyAlignedDkimPass": false,
        "dmarcPass": true,
        "anyAuthAligned": true
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; dmarc=pass header.from=example.com; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=evil.test",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            { "method": "dmarc", "result": "pass", "properties": { "header.from": "example.com" } },
            { "method": "spf", "result": "pass", "properties": { "smtp.mailfrom": "example.com" } },
            { "method": "dkim", "result": "pass", "properties": { "header.d": "evil.test" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "dkim.domainMismatch",
        "category": "consistency",
        "severity": "low",
        "message": "DKIM header.d signing domain differs from the From domain.",
        "data": {
          "fromDomain": "example.com",
          "dkimDomains": ["evil.test"],
          "mismatchedDomains": ["evil.test"]
        }
      }
    ]
  }
}
