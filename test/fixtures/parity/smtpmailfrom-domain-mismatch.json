          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
