{
  "family": "auth.method.failure",
  "description": "A trusted Authentication-Results header reports dmarc=fail. A trusted DMARC fail is the strongest single spoofing indicator and is reported at high severity — the only built-in signal that reaches 'high'. The failed result's header.from is excluded from dmarcHeaderFromDomains, so no dmarc.headerFromMismatch consistency signal is fabricated on top of the failure.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<id@example.com>",
      "authentication-results": [
        "mx.example.net; dmarc=fail header.from=example.com"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": [],
      "smtpMailfromDomainMatchesFromDomain": null,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": [],
      "dkimDomainMatchesFromDomain": null,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [
          { "result": "fail", "headerFrom": "example.com", "trusted": true }
        ],
        "spfResults": [],
        "dkimResults": [],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; dmarc=fail header.from=example.com",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            { "method": "dmarc", "result": "fail", "properties": { "header.from": "example.com" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.method.failure",
        "category": "auth-failure",
        "severity": "high",
        "message": "DMARC returned fail.",
        "data": {
          "method": "dmarc",
          "result": "fail",
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "header.from": "example.com" }
        }
      }
    ]
  }
}
