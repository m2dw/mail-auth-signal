{
  "family": "auth.method.failure",
  "description": "A trusted Authentication-Results header reports dkim=fail. A trusted, non-DMARC hard fail is reported at medium severity. The failed signature's header.d is deliberately excluded from dkimDomains (a broken signature authenticates nothing), so no dkim.domainMismatch consistency signal is fabricated.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<id@example.com>",
      "authentication-results": [
        "mx.example.net; dkim=fail header.d=example.com"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": [],
      "smtpMailfromDomainMatchesFromDomain": null,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": [],
      "dkimDomainMatchesFromDomain": null,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [],
        "spfResults": [],
        "dkimResults": [
          { "result": "fail", "headerD": "example.com", "headerI": null, "trusted": true }
        ],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; dkim=fail header.d=example.com",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            { "method": "dkim", "result": "fail", "properties": { "header.d": "example.com" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.method.failure",
        "category": "auth-failure",
        "severity": "medium",
        "message": "DKIM returned fail.",
        "data": {
          "method": "dkim",
          "result": "fail",
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "header.d": "example.com" }
        }
      }
    ]
  }
}
