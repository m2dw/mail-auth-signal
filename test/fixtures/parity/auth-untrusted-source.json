{
  "family": "auth.results.untrusted",
  "description": "Every authentication method passes, but the Authentication-Results header is stamped by an authserv-id the caller did not declare trusted (no trustedAuthservIds supplied). The forge-able source is flagged once at low severity in the 'trust' category. Because trust is not granted, the passing DMARC header.from is excluded from dmarcHeaderFromDomains, so no consistency signal fires.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<id@example.com>",
      "authentication-results": [
        "relay.unknown.test; dmarc=pass header.from=example.com; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com"
      ]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": ["example.com"],
      "dkimDomainMatchesFromDomain": true,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 0,
        "untrustedHeaderCount": 1,
        "dmarcResults": [
          { "result": "pass", "headerFrom": "example.com", "trusted": false }
        ],
        "spfResults": [
          { "result": "pass", "smtpMailfrom": "example.com", "trusted": false }
        ],
        "dkimResults": [
          { "result": "pass", "headerD": "example.com", "headerI": null, "trusted": false }
        ],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "authenticationResults": [
        {
          "raw": "relay.unknown.test; dmarc=pass header.from=example.com; spf=pass smtp.mailfrom=example.com; dkim=pass header.d=example.com",
          "authservId": "relay.unknown.test",
          "trusted": false,
          "methods": [
            { "method": "dmarc", "result": "pass", "properties": { "header.from": "example.com" } },
            { "method": "spf", "result": "pass", "properties": { "smtp.mailfrom": "example.com" } },
            { "method": "dkim", "result": "pass", "properties": { "header.d": "example.com" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.results.untrusted",
        "category": "trust",
        "severity": "low",
        "message": "Authentication-Results header was produced by an untrusted authserv-id.",
        "data": { "authservId": "relay.unknown.test" }
      }
    ]
  }
}
