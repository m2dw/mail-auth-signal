{
  "family": "auth.method.failure",
  "description": "A trusted Authentication-Results header reports spf=fail while smtp.mailfrom stays From-aligned (so no envelope consistency signal fires). A trusted, non-DMARC hard fail is reported at medium severity in the 'auth-failure' category; the failing method, result, source, and properties travel in the data payload under the single stable auth.method.failure key.",
  "input": {
    "headers": {
      "from": "Example Sender <notice@example.com>",
      "message-id": "<id@example.com>",
      "authentication-results": [
        "mx.example.net; spf=fail smtp.mailfrom=example.com"
      ]
    },
    "options": {
      "trustedAuthservIds": ["mx.example.net"]
    }
  },
  "expected": {
    "metrics": {
      "fromDomain": "example.com",
      "messageIdDomain": "example.com",
      "messageIdDomainMatchesFromDomain": true,
      "replyToDomains": [],
      "replyToDomainMatchesFromDomain": null,
      "returnPathDomain": null,
      "returnPathNullReversePath": false,
      "returnPathDomainMatchesFromDomain": null,
      "smtpMailfromDomains": ["example.com"],
      "smtpMailfromDomainMatchesFromDomain": true,
      "envelopeSenderDomainsAgree": null,
      "dkimDomains": [],
      "dkimDomainMatchesFromDomain": null,
      "dmarcHeaderFromDomains": [],
      "dmarcHeaderFromMatchesFromDomain": null,
      "authentication": {
        "trustedHeaderCount": 1,
        "untrustedHeaderCount": 0,
        "dmarcResults": [],
        "spfResults": [
          { "result": "fail", "smtpMailfrom": "example.com", "trusted": true }
        ],
        "dkimResults": [],
        "spfAlignedWithFrom": null,
        "dkimAlignedWithFrom": null,
        "anyAlignedSpfPass": false,
        "anyAlignedDkimPass": false,
        "dmarcPass": false,
        "anyAuthAligned": false
      },
      "senderIdentity": {
        "displayName": {
          "present": true,
          "text": "Example Sender",
          "length": 14,
          "hasNonAscii": false,
          "containsEmail": false,
          "embeddedDomains": [],
          "embeddedDomainMatchesFromDomain": null
        },
        "localPart": "notice",
        "localPartLexical": { "length": 6, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainLexical": { "length": 11, "digitCount": 0, "hyphenCount": 0, "hasNonAscii": false },
        "fromDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdDomainParts": {
          "domain": "example.com",
          "labels": ["example", "com"],
          "labelCount": 2,
          "topLabel": "com",
          "registrableDomain": null,
          "subdomainDepth": null
        },
        "messageIdRegistrableDomainMatchesFromDomain": null,
        "fromDomainIsPublicMailboxProvider": false,
        "publicMailboxProviderId": null
      },
      "authenticationResults": [
        {
          "raw": "mx.example.net; spf=fail smtp.mailfrom=example.com",
          "authservId": "mx.example.net",
          "trusted": true,
          "methods": [
            { "method": "spf", "result": "fail", "properties": { "smtp.mailfrom": "example.com" } }
          ]
        }
      ]
    },
    "signals": [
      {
        "key": "auth.method.failure",
        "category": "auth-failure",
        "severity": "medium",
        "message": "SPF returned fail.",
        "data": {
          "method": "spf",
          "result": "fail",
          "authservId": "mx.example.net",
          "trusted": true,
          "properties": { "smtp.mailfrom": "example.com" }
